alias r='my_ruby'
function my_ruby() {
    if [ -f ./Gemfile ]; then
        if [ -n "$INSIDE_EMACS" ]; then
            rails console -- --inf-ruby-mode
        else
            rails console
        fi
    else
        if [ -n "$INSIDE_EMACS" ]; then
            irb --inf-ruby-mode
        else
            irb
        fi
    fi
}

alias p='my_python'
function my_python() {
    if [ -x "$(command -v ipython)" ]; then
        if [ -n "$INSIDE_EMACS" ]; then
            ipython --simple-prompt "$@"
        else
            ipython "$@"
        fi
    elif [ -x "$(command -v python3)" ]; then
        python3 "$@"
    else
        python "$@"
    fi
}


# Run `less' if argument is a file, otherwise `ls'.
alias l='my_ls'
function my_ls() {
  if [ $# = 1 ]; then
    if [ -f $1 ]; then
      less $1;
      return
    fi
  fi
  ll $*;
}

alias c="cd_ls"
function cd_ls () {
   if [ $# = 0 ]; then
      cd && ls -G
   else
      cd "$*" && ls -G
   fi
}

