# -*- mode: sh -*-

typeset -U path PATH

path=(~/my/dotfiles/bin "$path[@]")

# asdf
# https://asdf-vm.com/guide/getting-started.html
if [[ -e "$HOME/.asdf/asdf.sh" ]]; then
  echo loading asdf.sh
  . "$HOME/.asdf/asdf.sh"
  # append completions to fpath
  fpath=(${ASDF_DIR}/completions $fpath)
fi

if [[ -e ~/.rbenv/bin/rbenv ]]; then
  eval "$(~/.rbenv/bin/rbenv init - zsh)"
fi

# https://unix.stackexchange.com/questions/273861/unlimited-history-in-zsh
HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt BANG_HIST                 # Treat the '!' character specially during expansion.
setopt EXTENDED_HISTORY          # Write the history file in the ":start:elapsed;command" format.
setopt INC_APPEND_HISTORY        # Write to the history file immediately, not when the shell exits.
setopt SHARE_HISTORY             # Share history between all sessions.
setopt HIST_EXPIRE_DUPS_FIRST    # Expire duplicate entries first when trimming history.
setopt HIST_IGNORE_DUPS          # Don't record an entry that was just recorded again.
setopt HIST_IGNORE_ALL_DUPS      # Delete old recorded entry if new entry is a duplicate.
setopt HIST_FIND_NO_DUPS         # Do not display a line previously found.
setopt HIST_IGNORE_SPACE         # Don't record an entry starting with a space.
setopt HIST_SAVE_NO_DUPS         # Don't write duplicate entries in the history file.
setopt HIST_REDUCE_BLANKS        # Remove superfluous blanks before recording entry.
setopt HIST_VERIFY               # Don't execute immediately upon history expansion.
setopt HIST_BEEP                 # Beep when accessing nonexistent history.

export PYTHONSTARTUP=~/.pythonrc.py
export RIPGREP_CONFIG_PATH=~/.ripgreprc

# initialise completions with ZSH's compinit
autoload -Uz compinit && compinit

# Load Git prompt functions
# --- git branch ---
autoload -Uz vcs_info
zstyle ':vcs_info:git:*' formats '(%b)'
zstyle ':vcs_info:*' enable git

# --- track command start time ---
preexec() {
  cmd_start_time=$SECONDS
}

# --- prompt ---
custom_prompt() {
  # MUST be first
  local last_exit_status=$?

  local cmd_duration=$((SECONDS - cmd_start_time))
  vcs_info

  # detect emacs / dumb terminal
  local in_emacs=0
  if [[ -n "$INSIDE_EMACS" || "$TERM" == "dumb" ]]; then
    in_emacs=1
  fi

  local prompt_status time_str dir_str branch_str duration_str arrow

  if [[ $in_emacs -eq 1 ]]; then
    # plain ascii, no colors
    time_str="$(date +%H:%M:%S)"
    dir_str="[${PWD/#$HOME/~}]"
    branch_str="${vcs_info_msg_0_}"

    if [[ $last_exit_status -eq 0 ]]; then
      prompt_status="OK"
    else
      prompt_status="ERR($last_exit_status)"
    fi

    duration_str="{${cmd_duration}s:${prompt_status}}"
    arrow="> "

    PROMPT="${time_str} ${dir_str} ${branch_str} ${duration_str}"$'\n'"${arrow}"
  else
    # fancy version
    local status_symbol
    if [[ $last_exit_status -eq 0 ]]; then
      status_symbol="%F{green}✔%f"
    else
      status_symbol="%F{red}✘%f"
    fi

    PROMPT="%F{cyan}%D{%H:%M:%S}%f %F{magenta}[%~]%f ${vcs_info_msg_0_} {${cmd_duration}s:${status_symbol}}"$'\n'"→ "
  fi
}

precmd() {
  custom_prompt
}

if [[ -e $HOME/.cargo/env ]]; then
  . $HOME/.cargo/env
fi


# Aliases
alias sub="/Applications/Sublime\ Text.app/Contents/SharedSupport/bin/subl"

